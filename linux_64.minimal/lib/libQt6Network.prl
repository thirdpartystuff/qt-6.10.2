QMAKE_PRL_TARGET = libQt6Network.a
QMAKE_PRL_CONFIG = static
QMAKE_PRL_VERSION = 6.10.2
QMAKE_PRL_LIBS = $$[QT_INSTALL_LIBS]/libQt6Core.a $$[QT_INSTALL_LIBS]/libQt6BundledZLIB.a -lm $$[QT_INSTALL_LIBS]/libQt6BundledPcre2.a -lrt
QMAKE_PRL_LIBS_FOR_CMAKE = $$[QT_INSTALL_LIBS]/libQt6Core.a;$$[QT_INSTALL_LIBS]/libQt6BundledZLIB.a;-lm;$$[QT_INSTALL_LIBS]/libQt6BundledPcre2.a;-lrt
